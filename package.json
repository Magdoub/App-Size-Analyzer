{
  "name": "sizeanalyzer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Client-side binary analysis platform for iOS & Android app size optimization",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext js,vue --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,vue --fix",
    "format": "prettier --write \"src/**/*.{js,vue,css}\""
  },
  "keywords": [
    "binary",
    "analyzer",
    "ios",
    "android",
    "optimization",
    "app-size"
  ],
  "author": "",
  "license": "MIT",
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "dependencies": {
    "@plist/plist": "^1.0.0",
    "@tanstack/vue-virtual": "^3.13.12",
    "app-info-parser": "^1.1.6",
    "color2k": "^2.0.3",
    "comlink": "^4.4.2",
    "echarts": "^5.5.0",
    "fflate": "^0.8.2",
    "pinia": "^2.3.1",
    "protobufjs": "^7.5.4",
    "tailwindcss": "^3.4.18",
    "vue": "^3.5.24",
    "vue-echarts": "^7.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@vitejs/plugin-vue": "^4.6.2",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
