/**
 * App - Root component with view routing
 */

import { useState } from 'react';
import { useAnalysisStore } from './store/analysis-store';
import { ErrorBoundary } from './components/shared/ErrorBoundary';
import { LoadingSpinner } from './components/shared/LoadingSpinner';
import { UploadZone } from './components/upload/UploadZone';
import { FileValidator, type ValidationResult } from './components/upload/FileValidator';
import { BreakdownView } from './components/breakdown/BreakdownView';
import { parseIPA } from './lib/parsers/ios/ipa-parser';
import { parseAPK } from './lib/parsers/android/apk-parser';
import { buildBreakdownTree, validateTreeSize } from './lib/analysis/breakdown-generator';
import { extractZIP } from './lib/parsers/common/zip-parser';
import { detectContentType } from './lib/parsers/common/types';
import type { FileEntry, AnalysisContext } from './types/analysis';

function App() {
  const {
    currentView,
    isLoading,
    loadingStatus,
    loadingProgress,
    error,
    setCurrentAnalysis,
    setLoading,
    setError,
    setCurrentView,
  } = useAnalysisStore();

  const [selectedFile, setSelectedFile] = useState<File | null>(null);
  const [validationResult, setValidationResult] = useState<ValidationResult | null>(null);

  // Handle file selection
  const handleFileSelect = (file: File) => {
    setSelectedFile(file);
    setError(null);
  };

  // Handle validation result
  const handleValidated = async (result: ValidationResult) => {
    setValidationResult(result);

    if (!result.valid || !selectedFile) {
      setError(result.error || 'Validation failed');
      return;
    }

    // Start analysis
    await analyzeFile(selectedFile, result.platform!);
  };

  // Analyze the file
  const analyzeFile = async (file: File, platform: 'iOS' | 'Android') => {
    try {
      setLoading(true, 10, 'Extracting archive...');
      setError(null);

      // Extract ZIP entries
      const entries = await extractZIP(file);

      setLoading(true, 30, 'Parsing metadata...');

      let analysis: AnalysisContext;

      if (platform === 'iOS') {
        // Parse IPA
        const ipaResult = await parseIPA(file);

        // Convert to FileEntry format
        const fileEntries: FileEntry[] = entries.map((entry) => ({
          path: entry.name,
          size: entry.uncompressedSize,
          compressedSize: entry.compressedSize,
          type: detectContentType(entry.name),
          metadata: {},
        }));

        setLoading(true, 60, 'Building breakdown tree...');

        // Build breakdown tree
        const breakdownRoot = buildBreakdownTree(fileEntries);

        // Validate tree
        const isValid = validateTreeSize(breakdownRoot, ipaResult.totalSize);
        if (!isValid) {
          console.warn('Tree size validation failed - size mismatch detected');
        }

        analysis = {
          fileId: `${file.name}-${Date.now()}`,
          timestamp: new Date(),
          platform,
          appName: ipaResult.metadata.displayName,
          bundleId: ipaResult.metadata.bundleId,
          version: ipaResult.metadata.version,
          totalInstallSize: ipaResult.installSize,
          totalDownloadSize: ipaResult.downloadSize,
          breakdownRoot,
          allFiles: fileEntries,
          // iOS-specific data
          frameworks: ipaResult.frameworks.map((fw) => ({
            name: fw.name,
            path: fw.path,
            size: fw.size,
          })),
          assets: ipaResult.assets.map((asset) => ({
            path: asset.path,
            type: asset.type,
            size: asset.size,
          })),
          localizations: ipaResult.localizations,
        };
      } else {
        // Parse APK
        const apkResult = await parseAPK(file);

        // Convert to FileEntry format
        const fileEntries: FileEntry[] = entries.map((entry) => ({
          path: entry.name,
          size: entry.uncompressedSize,
          compressedSize: entry.compressedSize,
          type: detectContentType(entry.name),
          metadata: {},
        }));

        setLoading(true, 60, 'Building breakdown tree...');

        // Build breakdown tree
        const breakdownRoot = buildBreakdownTree(fileEntries);

        // Validate tree
        const isValid = validateTreeSize(breakdownRoot, apkResult.totalSize);
        if (!isValid) {
          console.warn('Tree size validation failed - size mismatch detected');
        }

        analysis = {
          fileId: `${file.name}-${Date.now()}`,
          timestamp: new Date(),
          platform,
          appName: apkResult.metadata.applicationLabel || apkResult.metadata.packageName,
          bundleId: apkResult.metadata.packageName,
          version: apkResult.metadata.versionName,
          totalInstallSize: apkResult.installSize,
          totalDownloadSize: apkResult.downloadSize,
          breakdownRoot,
          allFiles: fileEntries,
          // Android-specific data
          nativeLibs: apkResult.nativeLibs.map((lib) => ({
            name: lib.name,
            path: lib.path,
            size: lib.size,
            architecture: lib.architecture,
          })),
          dexFiles: apkResult.dexFiles.map((dex, idx) => ({
            name: `classes${idx > 0 ? idx + 1 : ''}.dex`,
            methodCount: dex.methodCount,
            size: dex.fileSize,
          })),
        };
      }

      setLoading(true, 90, 'Finalizing analysis...');

      // Store analysis and navigate to breakdown view
      setCurrentAnalysis(analysis);
      setCurrentView('breakdown');

      setLoading(false, 100, 'Complete');
    } catch (err) {
      setError(
        err instanceof Error ? err.message : 'An unexpected error occurred during analysis'
      );
      setLoading(false);
    }
  };

  return (
    <ErrorBoundary>
      <div className="min-h-screen bg-gray-50">
        {/* Header */}
        <header className="bg-white shadow-sm">
          <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <h1 className="text-2xl font-bold text-gray-900">App Size Analyzer</h1>
            <p className="text-sm text-gray-500">
              Client-side binary analysis for iOS & Android
            </p>
          </div>
        </header>

        {/* Main Content */}
        <main className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
          {error && (
            <div className="mb-4 bg-red-50 border border-red-200 rounded-md p-4">
              <p className="text-sm text-red-800">{error}</p>
            </div>
          )}

          {isLoading ? (
            <LoadingSpinner size="lg" message={loadingStatus} progress={loadingProgress} />
          ) : (
            <div className="bg-white shadow rounded-lg p-8">
              {currentView === 'upload' && (
                <div>
                  <UploadZone
                    onFileSelect={handleFileSelect}
                    acceptedFormats={['.ipa', '.apk', '.aab', '.xapk']}
                    maxSizeMB={2000}
                  />

                  {selectedFile && (
                    <FileValidator
                      file={selectedFile}
                      onValidated={handleValidated}
                      maxSizeMB={2000}
                    />
                  )}
                </div>
              )}

              {currentView === 'breakdown' && <BreakdownView />}

              {currentView === 'xray' && (
                <div>
                  <h2 className="text-xl font-semibold text-gray-900 mb-4">X-Ray Treemap</h2>
                  <p className="text-gray-600">
                    Interactive treemap will be displayed here (Phase 4)
                  </p>
                </div>
              )}

              {currentView === 'insights' && (
                <div>
                  <h2 className="text-xl font-semibold text-gray-900 mb-4">Insights</h2>
                  <p className="text-gray-600">
                    Optimization recommendations will be displayed here (Phase 5)
                  </p>
                </div>
              )}
            </div>
          )}
        </main>

        {/* Footer */}
        <footer className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 mt-8">
          <p className="text-center text-sm text-gray-500">
            Phase 3: MVP - User Story 1 in progress
          </p>
        </footer>
      </div>
    </ErrorBoundary>
  );
}

export default App;
